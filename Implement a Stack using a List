stack=[]
while True:
    ch=int(input("1.Push 2.Pop 3.Display 4.Exit:"))
    if ch==1:
        stack.append(int(input("Element:")))
    elif ch==2:
        if stack:
            print(stack.pop())
        else:
            print("Stack Empty")
    elif ch==3:
        print(stack)
    else:
        break
