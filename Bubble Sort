n=int(input("Enter number of elements: "))
lst=[]
for i in range(n):
    lst.append(int(input()))
for i in range(n-1):
    for j in range(n-i-1):
        if lst[j]>lst[j+1]:
            temp=lst[j]
            lst[j]=lst[j+1]
            lst[j+1]=temp
print("Sorted List:")
for i in lst:
    print(i,end=" ")
