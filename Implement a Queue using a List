queue=[]
while True:
    ch=int(input("1.Insert 2.Delete 3.Display 4.Exit:"))
    if ch==1:
        queue.append(int(input("Element:")))
    elif ch==2:
        if queue:
            print(queue.pop(0))
        else:
            print("Queue Empty")
    elif ch==3:
        print(queue)
    else:
        break
